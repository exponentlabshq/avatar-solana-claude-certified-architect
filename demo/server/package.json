{
  "name": "solana-mpp-demo-server",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --prefix ../../typescript/packages/mpp",
    "dev": "tsx watch --clear-screen=false index.ts",
    "prestart": "npm run build --prefix ../../typescript/packages/mpp",
    "start": "tsx index.ts",
    "kill-demo": "for p in 3000 5173 5174 5175 5176 5177 5178 5179 5180; do for i in $(lsof -ti tcp:$p 2>/dev/null); do kill -9 $i 2>/dev/null; done; done; echo done"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "@solana/mpp": "file:../../typescript/packages/mpp",
    "@solana/kit": "^6.4.0",
    "mppx": "^0.3.15",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
